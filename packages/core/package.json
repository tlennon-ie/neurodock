{
  "name": "@neurodock/core",
  "version": "0.0.1",
  "private": false,
  "description": "Shared types, profile schema, and plugin protocol for NeuroDock.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tlennon-ie/neurodock.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tlennon-ie/neurodock#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit && echo 'core: lint via tsc strict mode'",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "vitest": "^3.2.6"
  }
}
