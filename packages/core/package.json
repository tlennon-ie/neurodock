{
  "name": "@neurodock/core",
  "version": "0.1.0",
  "private": false,
  "description": "Shared types, profile schema, and plugin protocol for NeuroDock.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "data/neurotype-addenda/v1.json",
    "schemas",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tlennon-ie/neurodock.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tlennon-ie/neurodock#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit && echo 'core: lint via tsc strict mode'",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "vitest": "^3.2.6",
    "yaml": "^2.8.3"
  }
}
