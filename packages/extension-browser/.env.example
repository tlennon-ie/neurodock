# NeuroDock browser extension — environment variables
#
# All values are local-first. The extension defaults to local mode with NO
# remote calls; setting these variables only affects DEFAULTS at install
# time. Per plan.md §7 the user retains ultimate control via the popup.

# Default mode. One of: local | cloud. Default: local.
NEURODOCK_DEFAULT_MODE=local

# Default local LLM endpoint. Ollama defaults to 11434.
# Reached via runtime optional_host_permission (not in default manifest).
NEURODOCK_LOCAL_ENDPOINT=http://localhost:11434

# Default local model id. Aligns with mcp-translation examples.
NEURODOCK_LOCAL_MODEL=llama3.1:8b-instruct
