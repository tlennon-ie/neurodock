# NeuroDock environment variables
#
# NeuroDock is local-first: it reads everything it needs from
# ~/.neurodock/profile.yaml and does not require any environment
# variables to run. These variables exist for testing, packaging, and
# advanced configuration. Copy to `.env` only if you need an override.
#
# Variables are documented in source-of-truth order:
#   1. profile + storage paths
#   2. runtime behaviour
#   3. test-only / development flags
#
# Anything listed below is what the code actually reads. If you add a
# new env var to a package, also add it here.

# -----------------------------------------------------------------------
# 1. Profile + storage paths
# -----------------------------------------------------------------------

# Override the location of the user profile YAML.
# Loader precedence: NEURODOCK_PROFILE_PATH > $XDG_CONFIG_HOME/neurodock/profile.yaml
#                    > ~/.neurodock/profile.yaml > ./profile.yaml
# Source: packages/mcp-chronometric/src/neurodock_mcp_chronometric/profile.py,
#         packages/core/schemas/profile.schema.json, packages/cli/src/paths.ts,
#         packages/native-host/src/profile-io.ts
# Default: ~/.neurodock/profile.yaml
# NEURODOCK_PROFILE_PATH=/absolute/path/to/profile.yaml

# Override the SQLite cognitive-graph database location.
# Source: packages/mcp-cognitive-graph/src/neurodock_mcp_cognitive_graph/config.py
# Default: ~/.neurodock/cognitive-graph.sqlite
# NEURODOCK_GRAPH_DB_PATH=/absolute/path/to/cognitive-graph.sqlite

# -----------------------------------------------------------------------
# 2. Runtime behaviour
# -----------------------------------------------------------------------

# Selects the task-fractionator's task source backend.
# Allowed values: memory | graph
# Source: packages/mcp-task-fractionator/src/neurodock_mcp_task_fractionator/sources/base.py
# Default: memory
# NEURODOCK_TASK_SOURCE=memory

# Disable the cognitive-graph's embedding-based entity resolution rung.
# Set to "1" to skip embedding lookups (useful in air-gapped envs and CI
# where downloading the fastembed model is undesirable). Other rungs
# (exact / alias / fuzzy) still run.
# Source: packages/mcp-cognitive-graph/src/neurodock_mcp_cognitive_graph/embeddings.py
# Default: unset (embeddings enabled)
# NEURODOCK_GRAPH_DISABLE_EMBEDDINGS=

# -----------------------------------------------------------------------
# 3. Test-only / development flags
# -----------------------------------------------------------------------

# Opt-in flag for the cognitive-graph embedding integration tests. They
# download the fastembed model on first run and are excluded from the
# default `pytest` run.
# Source: packages/mcp-cognitive-graph/tests/test_embedding_resolution.py
# Default: unset (integration tests skipped)
# NEURODOCK_GRAPH_RUN_EMBEDDING_INTEGRATION=
